# Ambiente
NODE_ENV=development
PORT=3000

# Banco de Dados
DATABASE_URL=postgresql://1cup_user:1cup_pass@localhost:5432/1cup_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT — Use strings longas e aleatórias (min 32 chars)
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=SUBSTITUA_POR_SECRET_REAL_MIN_32_CHARS
JWT_REFRESH_SECRET=SUBSTITUA_POR_SECRET_DIFERENTE_MIN_32_CHARS

# Storage (Cloudflare R2 ou AWS S3)
S3_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
S3_BUCKET=1cup-media
S3_ACCESS_KEY=SUBSTITUA
S3_SECRET_KEY=SUBSTITUA
S3_PUBLIC_URL=https://media.1cup.app

# CORS (lista separada por vírgula)
CORS_ORIGIN=http://localhost:3001,https://1cup.app

# Bcrypt
BCRYPT_ROUNDS=12

# E-mail (para reset de senha)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SUBSTITUA
SMTP_FROM=noreply@1cup.app
