generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USUÁRIO
// ============================================================
model User {
  id           String   @id @default(cuid())
  username     String   @unique @db.VarChar(30)
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name") @db.VarChar(60)
  bio          String?  @db.VarChar(300)
  avatarUrl    String?  @map("avatar_url")
  role         UserRole @default(USER)
  isVerified   Boolean  @default(false) @map("is_verified")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  checkins              CheckIn[]
  refreshTokens         RefreshToken[]
  passwordResetTokens   PasswordResetToken[]
  emailVerifications    EmailVerificationToken[]
  friendships           Friendship[]     @relation("UserFriendships")
  friendOf              Friendship[]     @relation("FriendFriendships")
  badges                UserBadge[]
  suggestions           EditSuggestion[]
  coffeesCadastrados    Coffee[]         @relation("CoffeeCreator")
  roasteriesCadastradas Roastery[]       @relation("RoasteryCreator")
  producersCadastrados  Producer[]       @relation("ProducerCreator")

  // Phase 8 — product depth
  likes                 CheckInLike[]
  comments              Comment[]
  follows               Follow[]
  notifications         Notification[]   @relation("NotificationRecipient")
  notificationsActed    Notification[]   @relation("NotificationActor")
  blocksMade            Block[]          @relation("Blocker")
  blocksReceived        Block[]          @relation("Blocked")
  reportsMade           Report[]         @relation("Reporter")
  reportsReviewed       Report[]         @relation("ReportReviewer")

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

// ============================================================
// AUTENTICAÇÃO
// ============================================================
model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique // SHA-256 hash of the emailed token — never the raw value
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique // SHA-256 hash of the emailed token
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

// ============================================================
// AMIZADE
// ============================================================
model Friendship {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  friendId  String           @map("friend_id")
  status    FriendshipStatus @default(PENDING)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user   User @relation("UserFriendships", fields: [userId], references: [id])
  friend User @relation("FriendFriendships", fields: [friendId], references: [id])

  @@unique([userId, friendId])
  @@map("friendships")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

// ============================================================
// PRODUTOR (fazenda)
// ============================================================
model Producer {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(120)
  farmName  String?  @map("farm_name") @db.VarChar(120)
  city      String?  @db.VarChar(80)
  state     String?  @db.VarChar(80)
  country   String?  @db.VarChar(60) @default("Brasil")
  altitude  String?  @db.VarChar(40)
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creator     User?            @relation("ProducerCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  coffees     Coffee[]
  suggestions EditSuggestion[]

  @@map("producers")
}

// ============================================================
// TORREFAÇÃO
// ============================================================
model Roastery {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(120)
  city      String?  @db.VarChar(80)
  state     String?  @db.VarChar(80)
  country   String?  @db.VarChar(60) @default("Brasil")
  instagram String?  @db.VarChar(60)
  website   String?  @db.VarChar(200)
  logoUrl   String?  @map("logo_url")
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creator     User?            @relation("RoasteryCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  coffees     Coffee[]
  suggestions EditSuggestion[]
  followers   Follow[]

  @@map("roasteries")
}

// ============================================================
// CAFÉ
// ============================================================
model Coffee {
  id            String      @id @default(cuid())
  name          String      @db.VarChar(120)
  roasteryId    String      @map("roastery_id")
  producerId    String?     @map("producer_id")
  labelImageUrl String?     @map("label_image_url")
  variety       String?     @db.VarChar(80)
  roastColor    RoastColor? @map("roast_color")
  processMethod String?     @map("process_method") @db.VarChar(60)
  tastingNotes  String[]    @map("tasting_notes")
  scaScore      Decimal?    @map("sca_score") @db.Decimal(4, 2)
  brewMethods   String[]    @map("brew_methods")
  isActive      Boolean     @default(true) @map("is_active")
  createdBy     String?     @map("created_by")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  roastery    Roastery         @relation(fields: [roasteryId], references: [id])
  producer    Producer?        @relation(fields: [producerId], references: [id])
  creator     User?            @relation("CoffeeCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  checkins    CheckIn[]
  suggestions EditSuggestion[]
  followers   Follow[]

  @@index([roasteryId])
  @@index([producerId])
  @@index([isActive])
  @@map("coffees")
}

enum RoastColor {
  LIGHT
  LIGHT_MEDIUM
  MEDIUM
  MEDIUM_DARK
  DARK
}

// ============================================================
// CHECK-IN
// ============================================================
model CheckIn {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  coffeeId     String   @map("coffee_id")
  rating       Int
  description  String?  @db.VarChar(500)
  brewMethod   String?  @map("brew_method") @db.VarChar(60)
  locationLat  Decimal? @map("location_lat") @db.Decimal(10, 7)
  locationLng  Decimal? @map("location_lng") @db.Decimal(10, 7)
  locationName String?  @map("location_name") @db.VarChar(120)
  photos       String[] @default([])
  isPublic     Boolean  @default(true) @map("is_public")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  coffee Coffee @relation(fields: [coffeeId], references: [id])

  likes         CheckInLike[]
  comments      Comment[]
  notifications Notification[]

  @@index([userId])
  @@index([coffeeId])
  @@index([createdAt])
  @@map("checkins")
}

// ============================================================
// BADGES / CONQUISTAS
// ============================================================
model Badge {
  id          String        @id @default(cuid())
  slug        String        @unique @db.VarChar(60)
  name        String        @db.VarChar(60)
  description String        @db.VarChar(200)
  iconName    String        @map("icon_name") @db.VarChar(60)
  tier        BadgeTier     @default(BRONZE)
  category    BadgeCategory @default(MILESTONE)
  rule        Json
  isActive    Boolean       @default(true) @map("is_active")

  userBadges UserBadge[]

  @@map("badges")
}

enum BadgeTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum BadgeCategory {
  MILESTONE // total check-ins
  EXPLORER // variety of coffees/countries/roasteries
  CONNOISSEUR // taste/quality focused
  SOCIAL // friends, likes, comments
  DEDICATION // streaks, habits, timing
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  badgeId  String   @map("badge_id")
  earnedAt DateTime @default(now()) @map("earned_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

// ============================================================
// SUGESTÕES DE EDIÇÃO
// ============================================================
model EditSuggestion {
  id         String           @id @default(cuid())
  entityType SuggestionEntity @map("entity_type")
  // Exactly one of the three target columns is set, matching `entityType`.
  // (Previously a single `entityId` carried three FK constraints at once, which
  // is unsatisfiable in PostgreSQL and blocked all inserts.)
  coffeeId   String?          @map("coffee_id")
  producerId String?          @map("producer_id")
  roasteryId String?          @map("roastery_id")
  userId     String           @map("user_id")
  payload    Json
  status     SuggestionStatus @default(PENDING)
  reviewedBy String?          @map("reviewed_by")
  reviewNote String?          @map("review_note")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  coffee   Coffee?   @relation(fields: [coffeeId], references: [id], onDelete: Cascade)
  producer Producer? @relation(fields: [producerId], references: [id], onDelete: Cascade)
  roastery Roastery? @relation(fields: [roasteryId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([coffeeId])
  @@map("edit_suggestions")
}

enum SuggestionEntity {
  COFFEE
  PRODUCER
  ROASTERY
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================
// WAITLIST (landing page)
// ============================================================
model Waitlist {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(80)
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("waitlist")
}

// ============================================================
// PHASE 8 — SOCIAL DEPTH
// ============================================================

// A single "like" on a check-in. One per (user, check-in).
model CheckInLike {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  checkinId String   @map("checkin_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkin CheckIn @relation(fields: [checkinId], references: [id], onDelete: Cascade)

  @@unique([userId, checkinId])
  @@index([checkinId])
  @@map("checkin_likes")
}

// A comment on a check-in.
model Comment {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  checkinId String   @map("checkin_id")
  body      String   @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkin CheckIn @relation(fields: [checkinId], references: [id], onDelete: Cascade)

  @@index([checkinId, createdAt])
  @@map("comments")
}

// Following a coffee or a roastery. Exactly one target column is set (mirrors
// the fixed EditSuggestion pattern — no polymorphic single-column FK).
model Follow {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  coffeeId   String?  @map("coffee_id")
  roasteryId String?  @map("roastery_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  coffee   Coffee?   @relation(fields: [coffeeId], references: [id], onDelete: Cascade)
  roastery Roastery? @relation(fields: [roasteryId], references: [id], onDelete: Cascade)

  @@unique([userId, coffeeId])
  @@unique([userId, roasteryId])
  @@index([coffeeId])
  @@index([roasteryId])
  @@map("follows")
}

enum NotificationType {
  LIKE
  COMMENT
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  NEW_COFFEE
  BADGE_EARNED
}

// In-app notification for a recipient user.
model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id") // recipient
  type      NotificationType
  actorId   String?          @map("actor_id") // who triggered it
  checkinId String?          @map("checkin_id")
  coffeeId  String?          @map("coffee_id")
  data      Json? // small denormalized payload for rendering
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user    User     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor   User?    @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  checkin CheckIn? @relation(fields: [checkinId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

// Directional block: blocker no longer interacts with blocked.
model Block {
  id        String   @id @default(cuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

enum ReportEntity {
  CHECKIN
  COMMENT
  USER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

// User-submitted report of abusive content, reviewed by admins.
model Report {
  id         String       @id @default(cuid())
  reporterId String       @map("reporter_id")
  entityType ReportEntity @map("entity_type")
  entityId   String       @map("entity_id")
  reason     String       @db.VarChar(60)
  note       String?      @db.VarChar(500)
  status     ReportStatus @default(PENDING)
  reviewedBy String?      @map("reviewed_by")
  reviewNote String?      @map("review_note") @db.VarChar(300)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  reporter User  @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer User? @relation("ReportReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([entityType, entityId])
  @@map("reports")
}
