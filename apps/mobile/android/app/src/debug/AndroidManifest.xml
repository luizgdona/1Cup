<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Debug-only: allows plaintext HTTP so the emulator default
         (http://10.0.2.2:3000, see AppConfig.apiBaseUrl) works without
         requiring a network security config. Never present in release —
         this file only merges into debug builds. -->
    <application android:usesCleartextTraffic="true" />
</manifest>
